{
  "name": "dsb-digital",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --fix --quiet && postcss src/index.css -o /dev/null",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "preview": "vite preview",
    "test": "bun tests/social-sharing.smoke.mjs && bun tests/analytics.smoke.mjs && bun tests/exporters.smoke.mjs && bun tests/seo-cluster.smoke.mjs && bun tests/case-studies.smoke.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "@upstash/redis": "^1.38.0",
    "clsx": "^2.1.1",
    "framer-motion": "^10.18.0",
    "isbot": "^5.1.40",
    "lucide-react": "^0.552.0",
    "only-allow": "^1.2.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^7.9.6",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "ua-parser-js": "^2.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^20.19.18",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.15.0",
    "vite": "^7.2.7",
    "vite-plugin-client-error-logger": "^0.1.3",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-react-fiber-source": "^0.1.2"
  }
}
